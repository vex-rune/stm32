# ============================================================
# STM32CubeMX 生成的临时文件
# ============================================================
# STM32CubeMX 工程索引文件（指向 .ioc 文件的元数据）
.mxproject

# STM32CubeMX 锁定文件（标记工程被 IDE 打开）
.metadata/.lock

# STM32CubeMX 自动生成的备份文件
*.ioc.bak
*.ioc~

# ============================================================
# STM32CubeIDE / Eclipse 元数据
# ============================================================
# Eclipse 工作空间元数据（包含本地路径、用户偏好等）
.metadata/

# Eclipse C 项目描述文件（包含特定于本地环境的配置）
.cproject

# Eclipse 通用项目描述文件
.project

# Eclipse 插件设置目录
.settings/

# STM32CubeIDE 的 C 语言设置文件
.csettings

# SVD（System View Description）缓存，用于外设寄存器调试
*.scvd

# Eclipse 其他工程格式文件
*.ewt
*.eww
*.ewp

# STM32CubeIDE 默认的构建输出目录
Debug/
Release/

# ============================================================
# Keil MDK - 另一种常见 IDE
# ============================================================
# Keil μVision 窗口布局文件（个人偏好）
*.uvguix.*

# Keil 项目配置（个人调试配置）
*.uvoptx

# Keil 项目配置（工作区/工程文件，按需提交）
# *.uvprojx
# *.uvopt
# *.uvguix
# JLink 调试器配置
*.jlink

# Keil 构建输出目录
Objects/
Listings/

# ============================================================
# IAR Embedded Workbench
# ============================================================
# IAR 工作区/工程配置
*.eww
*.ewp
*.ewd

# IAR 调试相关
*.wsdt
*.wspos
*.wsopt

# IAR 构建输出目录
EWARM/
*/settings/
*/Debug/
*/Release/
*/Obj/
*/List/
*/Exe/

# ============================================================
# CMake - 构建系统生成的文件
# ============================================================
# CMake 构建目录
build/
build-*/
out/
cmake-build-*/

# CMake 缓存配置
CMakeCache.txt

# CMake 生成的中间文件目录
CMakeFiles/

# CMake 安装脚本
cmake_install.cmake

# CMake 安装清单
install_manifest.txt

# CTest 测试配置文件
CTestTestfile.cmake

# CMake FetchContent 下载的依赖
_deps/

# CMake 编译数据库（用于 clangd 等工具智能提示）
# 注：默认生成在 build/ 目录下，已被 build/ 覆盖
# compile_commands.json

# Ninja 构建工具生成的目录
.ninja_deps
.ninja_log

# Make 构建工具生成的文件
Makefile
*.make
*.mk

# ============================================================
# 构建产物 - 编译生成的文件
# ============================================================
# 自定义输出目录
bin/
lib/

# 编译目标文件
*.o
*.obj
*.lo
*.la

# 可执行文件（用于调试和烧录）
*.elf
*.exe
*.out

# Intel HEX 格式固件（用于烧录）
*.hex

# 二进制固件（用于直接烧录）
*.bin

# Motorola S-record 格式固件（用于烧录）
*.s19
*.srec

# 链接器生成的内存映射文件（用于分析内存使用）
*.map

# 汇编列表文件（用于调试分析）
*.lst
*.list
*.lss

# 依赖关系文件（Make 使用的增量编译信息）
*.d
*.dep

# 各段大小信息文件
*.size

# GCC 预编译头文件
*.gch
*.pch

# ar 库管理器输出
*.a
*.lib

# ============================================================
# 调试与烧录工具
# ============================================================
# OpenOCD 调试配置/日志
*.openocd
.openocd/

# ST-Link 工具相关
st-link/

# JLink 日志与设置
*.jlink
JLinkLog.txt
JLinkSettings.ini

# pyOCD 缓存
.pyocd_cache/

# ============================================================
# VSCode - 编辑器配置
# ============================================================
# 默认忽略整个 .vscode 目录（个人配置不应提交）
.vscode/

# 例外：以下文件需要提交到仓库，用于团队共享配置
# 团队统一的编辑器设置（缩进、字体等）
!.vscode/settings.json
# 团队统一的任务定义（构建、烧录等）
!.vscode/tasks.json
# 推荐安装的插件列表
!.vscode/extensions.json

# clangd/cpptools 生成的智能提示浏览数据库
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# ============================================================
# CLion / JetBrains - 编辑器配置
# ============================================================
# CLion 自动生成的 CMake 构建目录
cmake-build-*/
**/cmake-build-*/

# JetBrains 系列 IDE 配置（IntelliJ IDEA、CLion 等）
.idea/

# IntelliJ 模块文件
*.iml

# IntelliJ 工作区文件
*.iws

# ============================================================
# Trae / Cursor / 其他 AI 编辑器
# ============================================================
# Trae IDE 配置
.trae/

# Cursor 编辑器配置
.cursor/

# Continue（AI 编程助手）配置
.continue/

# ============================================================
# 通用文件 - 各系统/工具产生的临时文件
# ============================================================
# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.bak
*.backup
*~

# Vim 交换文件
*.swp
*.swo
*.swn

# Emacs 备份文件
\#*\#
.\#*

# macOS 文件系统元数据
.DS_Store
.AppleDouble
.LSOverride

# Windows 缩略图缓存
Thumbs.db
ehthumbs.db
ehthumbs_vista.db

# Windows 文件夹配置
desktop.ini

# Linux 回收站
.Trash-*

# ============================================================
# 凭据与本地配置 - 严禁提交
# ============================================================
# 环境变量文件
.env
.env.local
.env.*.local

# 凭据文件
*credentials*
*secrets*
*.pem
*.key
*.p12
*.pfx

# 烧录授权/许可证
*.lic

# ============================================================
# 用户特定文件 - 不应提交的个人文件
# ============================================================
# 各 IDE 生成的用户特定配置
*.user
*.user.*

# 项目本地说明/笔记（个人用）
TODO.local.md
NOTES.local.md

# ============================================================
# 大型数据集 / 烧录镜像（按需启用）
# ============================================================
# SD 卡镜像
*.img

# 压缩镜像
*.zip
*.7z
*.rar
*.tar
*.gz
*.bz2
*.xz

# 视频/音频（如有）
*.mp4
*.avi
*.mov
*.mp3
*.wav
